      "id": 100,
      "title": "Machine State Timeline",
      "type": "row"
    },
    {
      "datasource": "InfluxDB",
      "description": "Shows state transitions for each machine as colored bars. Green=PROCESSING, Red=FAILED, Yellow=BLOCKED, Orange=STARVED, Blue=IDLE, Purple=UNDER_REPAIR, Cyan=DEGRADED, Gray=PAUSED",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 80,
            "lineWidth": 0,
            "spanNulls": false
          },
          "mappings": [
            {
              "options": {
                "PROCESSING": {
                  "color": "green",
                  "index": 0,
                  "text": "PROCESSING"
                }
              },
              "type": "value"
            },
            {
              "options": {
                "FAILED": {
                  "color": "red",
                  "index": 1,
                  "text": "FAILED"
                }
              },
              "type": "value"
            },
            {
              "options": {
                "BLOCKED": {
                  "color": "yellow",
                  "index": 2,
                  "text": "BLOCKED"
                }
              },
              "type": "value"
            },
            {
              "options": {
                "STARVED": {
                  "color": "orange",
                  "index": 3,
                  "text": "STARVED"
                }
              },
              "type": "value"
            },
            {
              "options": {
                "IDLE": {
                  "color": "blue",
                  "index": 4,
                  "text": "IDLE"
                }
              },
              "type": "value"
            },
            {
              "options": {
                "UNDER_REPAIR": {
                  "color": "purple",
                  "index": 5,
                  "text": "UNDER_REPAIR"
                }
              },
              "type": "value"
            },
            {
              "options": {
                "PAUSED": {
                  "color": "text",
                  "index": 6,
                  "text": "PAUSED"
                }
              },
              "type": "value"
            },
            {
              "options": {
                "DEGRADED": {
                  "color": "#00bcd4",
                  "index": 7,
                  "text": "DEGRADED"
                }
              },
              "type": "value"
            }
          ]
        }
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 1
      },
      "id": 1,
      "options": {
        "mergeValues": true,
        "showValue": "auto",
        "alignValue": "left",
        "rowHeight": 0.9
      },
      "targets": [
        {
          "query": "from(bucket: \"manufacturing\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"sim_events\")\n  |> filter(fn: (r) => r.run_id =~ /^${run_id}$/)\n  |> filter(fn: (r) => r.event_type == \"STATE_CHANGE\")\n  |> filter(fn: (r) => r.source_type == \"machine\")\n  |> filter(fn: (r) => r._field == \"new_state\")\n  |> keep(columns: [\"_time\", \"_value\", \"source\"])\n  |> group(columns: [\"source\"])"
        }
      ],
      "title": "Machine State Timeline",
      "type": "state-timeline"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "id": 101,
      "title": "State Duration Analysis",
      "type": "row"
    },
    {
      "datasource": "InfluxDB",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "PROCESSING"
            },
            "properties": [
              {
