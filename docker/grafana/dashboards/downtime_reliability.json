          "query": "from(bucket: \"manufacturing\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"sim_events\")\n  |> filter(fn: (r) => r.run_id =~ /^${run_id}$/)\n  |> filter(fn: (r) => r.event_type == \"STATE_CHANGE\")\n  |> filter(fn: (r) => r._field == \"new_state\")\n  |> filter(fn: (r) => r._value == \"FAILED\" or r._value == \"UNDER_REPAIR\")\n  |> keep(columns: [\"_time\", \"_value\", \"source\", \"event_type\"])\n  |> rename(columns: {\"_value\": \"state\", \"_time\": \"time\"})\n  |> sort(columns: [\"time\"], desc: true)\n  |> limit(n: 100)"
        }
      ],
