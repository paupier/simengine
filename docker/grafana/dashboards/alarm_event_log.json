    {
      "datasource": "InfluxDB",
      "description": "Most recent 200 alarm events. Filter columns to narrow down. Severity: CRITICAL=machine failure, MEDIUM=quality alert, LOW=buffer, INFO=maintenance.",
      "fieldConfig": {
        "defaults": {
          "custom": { "filterable": true }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "time" }, "properties": [{ "id": "custom.width", "value": 180 }] },
          { "matcher": { "id": "byName", "options": "severity" }, "properties": [
            { "id": "custom.width", "value": 90 },
            {
              "id": "custom.displayMode",
              "value": "color-background"
            },
            {
              "id": "thresholds",
              "value": {
                "mode": "absolute",
                "steps": [{ "color": "blue", "value": null }]
              }
            },
            {
              "id": "mappings",
              "value": [
                { "type": "value", "options": { "CRITICAL": { "color": "red", "index": 0 }, "MEDIUM": { "color": "orange", "index": 1 }, "LOW": { "color": "yellow", "index": 2 }, "INFO": { "color": "blue", "index": 3 } } }
              ]
            }
          ]},
          { "matcher": { "id": "byName", "options": "source" }, "properties": [{ "id": "custom.width", "value": 80 }] },
          { "matcher": { "id": "byName", "options": "message" }, "properties": [{ "id": "custom.width", "value": 500 }] }
        ]
      },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 28 },
      "id": 7,
      "options": {
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "time" }]
      },
      "targets": [
        {
          "query": "from(bucket: \"manufacturing\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"sim_events\")\n  |> filter(fn: (r) => r.run_id =~ /^${run_id}$/)\n  |> filter(fn: (r) => r.event_type == \"ALARM\")\n  |> filter(fn: (r) => r._field == \"message\")\n  |> keep(columns: [\"_time\", \"_value\", \"source\", \"severity\"])\n  |> group()\n  |> rename(columns: {\"_value\": \"message\", \"_time\": \"time\"})\n  |> sort(columns: [\"time\"], desc: true)\n  |> limit(n: 200)"
        }
      ],
      "title": "Recent Alarm Events",
      "type": "table"
    }

