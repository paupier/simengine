{
  "title": "Manufacturing Causal Analysis",
  "version": "2.4",
  "settings": {
    "pagenumber": 0,
    "editable": true,
    "fullscreenEnabled": false,
    "parameters": {
      "neodash_run_id": ""
    }
  },
  "pages": [
    {
      "title": "Causal Chain Explorer",
      "id": "a1b2c3d4-0001-0001-0001-000000000001",
      "reports": [
        {
          "id": "a1b2c3d4-0001-0001-0001-000000000101",
          "title": "Select Run ID",
          "query": "MATCH (r:Run) RETURN r.run_id AS value ORDER BY r.start_wall_clock DESC",
          "type": "select",
          "width": 6,
          "height": 2,
          "x": 0,
          "y": 0,
          "fields": [],
          "selection": {},
          "settings": {
            "parameterName": "neodash_run_id",
            "type": "Free Text",
            "defaultValue": ""
          }
        },
        {
          "id": "a1b2c3d4-0001-0001-0001-000000000102",
          "title": "Causal Chain (last 6 hops)",
          "query": "MATCH path=(e1:Event {run_id: $neodash_run_id})-[:CAUSED*1..6]->(e2:Event) WHERE NOT ()-[:CAUSED]->(e1) RETURN path LIMIT 50\n",
          "type": "graph",
          "width": 12,
          "height": 4,
          "x": 0,
          "y": 2,
          "fields": [],
          "selection": {
            "Event": "new_state",
            "Machine": "name"
          },
          "settings": {
            "nodePositions": {},
            "defaultNodeSize": "medium",
            "nodeSizeProp": "size",
            "nodeColorProp": "color",
            "showPropertiesOnHover": true,
            "showPropertiesOnClick": true,
            "layout": "force-directed"
          }
        }
      ]
    },
    {
      "title": "Failure Patterns",
      "id": "a1b2c3d4-0002-0002-0002-000000000002",
      "reports": [
        {
          "id": "a1b2c3d4-0002-0002-0002-000000000201",
          "title": "Machines by Failure Count",
          "query": "MATCH (m:Machine {run_id: $neodash_run_id})-[:HAD_EVENT]->(e:Event) WHERE e.new_state IN ['FAILED','UNDER_REPAIR'] RETURN m.name AS Machine, count(e) AS Failures ORDER BY Failures DESC\n",
          "type": "bar",
          "width": 6,
          "height": 3,
          "x": 0,
          "y": 0,
          "fields": [],
          "selection": {
            "index": "Machine",
            "value": "Failures",
            "key": "Failures"
          },
          "settings": {
            "legend": false,
            "animate": true,
            "layout": "vertical",
            "marginLeft": 50,
            "marginRight": 24,
            "marginTop": 24,
            "marginBottom": 40,
            "labelSkipWidth": 0,
            "labelSkipHeight": 0
          }
        },
        {
          "id": "a1b2c3d4-0002-0002-0002-000000000202",
          "title": "Recent UNDER_REPAIR Events",
          "query": "MATCH (m:Machine {run_id: $neodash_run_id})-[:HAD_EVENT]->(e:Event) WHERE e.new_state = 'UNDER_REPAIR' RETURN m.name AS Machine, e.sim_time AS SimTime, e.old_state AS From ORDER BY SimTime DESC LIMIT 20\n",
          "type": "table",
          "width": 6,
          "height": 3,
          "x": 6,
          "y": 0,
          "fields": [],
          "selection": {},
          "settings": {
            "nodePositions": {}
          }
        }
      ]
    },
    {
      "title": "SPC Quality Impact",
      "id": "a1b2c3d4-0003-0003-0003-000000000003",
      "reports": [
        {
          "id": "a1b2c3d4-0003-0003-0003-000000000301",
          "title": "SPC Violation Chains",
          "query": "MATCH (e1:Event {run_id: $neodash_run_id})-[:CAUSED {type:'spc_quality_impact'}]->(e2:Event) RETURN e1.sim_time AS ViolationTime, e2.sim_time AS ImpactTime, e2.new_state AS Outcome LIMIT 100\n",
          "type": "table",
          "width": 12,
          "height": 3,
          "x": 0,
          "y": 0,
          "fields": [],
          "selection": {},
          "settings": {
            "nodePositions": {}
          }
        }
      ]
    },
    {
      "title": "Shift Breakdown",
      "id": "a1b2c3d4-0004-0004-0004-000000000004",
      "reports": [
        {
          "id": "a1b2c3d4-0004-0004-0004-000000000401",
          "title": "Events per Shift",
          "query": "MATCH (r:Run {run_id: $neodash_run_id})-[:HAD_SHIFT]->(s:Shift)<-[:OCCURRED_IN]-(e:Event) RETURN s.name AS Shift, s.number AS ShiftNum, count(e) AS Events ORDER BY ShiftNum\n",
          "type": "bar",
          "width": 12,
          "height": 3,
          "x": 0,
          "y": 0,
          "fields": [],
          "selection": {
            "index": "Shift",
            "value": "Events",
            "key": "Events"
          },
          "settings": {
            "legend": false,
            "animate": true,
            "layout": "vertical",
            "marginLeft": 50,
            "marginRight": 24,
            "marginTop": 24,
            "marginBottom": 40,
            "labelSkipWidth": 0,
            "labelSkipHeight": 0
          }
        }
      ]
    },
    {
      "title": "Cross-Run Comparison",
      "id": "a1b2c3d4-0005-0005-0005-000000000005",
      "reports": [
        {
          "id": "a1b2c3d4-0005-0005-0005-000000000501",
          "title": "All Runs",
          "query": "MATCH (r:Run) RETURN r.run_id AS RunID, r.scenario AS Scenario, COUNT {(r)-[:INCLUDES]->()} AS Nodes ORDER BY r.start_wall_clock DESC\n",
          "type": "table",
          "width": 12,
          "height": 3,
          "x": 0,
          "y": 0,
          "fields": [],
          "selection": {},
          "settings": {
            "nodePositions": {}
          }
        }
      ]
    }
  ]
}
